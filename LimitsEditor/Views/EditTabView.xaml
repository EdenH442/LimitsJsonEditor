<UserControl x:Class="LimitsEditor.Views.EditTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:editors="clr-namespace:LimitsEditor.Views.Editors"
             mc:Ignorable="d">
    <Grid Margin="8">
        <materialDesign:Card Padding="16" UniformCornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Edit Limit" />

                <editors:SubTestFieldsEditor Grid.Row="2" />

                <StackPanel Grid.Row="4"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <Button Margin="0,0,8,0"
                            Padding="14,6"
                            Command="{Binding CancelCommand}"
                            Content="Cancel" />
                    <Button Padding="14,6"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding SaveChangesCommand}"
                            Content="Save Changes" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
