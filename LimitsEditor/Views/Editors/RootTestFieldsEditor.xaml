<UserControl x:Class="LimitsEditor.Views.Editors.RootTestFieldsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="132" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Test Name" />
        <TextBox Grid.Row="0"
                 Grid.Column="2"
                 Text="{Binding EditableStepName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
        <TextBlock Grid.Row="2"
                   Grid.Column="2"
                   Foreground="IndianRed"
                   Style="{StaticResource SubtleTextStyle}"
                   Text="{Binding StepNameError}" />

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Test Type" />
        <ComboBox Grid.Row="4"
                  Grid.Column="2"
                  IsEditable="True"
                  ItemsSource="{Binding AvailableStepTypes}"
                  Text="{Binding EditableStepType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
        <TextBlock Grid.Row="6"
                   Grid.Column="2"
                   Foreground="IndianRed"
                   Style="{StaticResource SubtleTextStyle}"
                   Text="{Binding StepTypeError}" />
    </Grid>
</UserControl>
