<UserControl x:Class="LimitsEditor.Views.Editors.SubTestFieldsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid IsEnabled="{Binding IsEditorEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Visibility="{Binding ShowSubTestName, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="132" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Sub-Test Name" />
            <TextBox Grid.Column="2"
                     Text="{Binding SubTestName, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="132" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Limit Type" />
            <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding LimitEditor.LimitType, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Comparison" />
            <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding LimitEditor.ComparisonType, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Threshold Type" />
            <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding LimitEditor.ThresholdType, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Expected" />
            <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding LimitEditor.ExpectedRes, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

            <TextBlock Grid.Row="8" Grid.Column="0" Text="Low" />
            <TextBox Grid.Row="8" Grid.Column="2" Text="{Binding LimitEditor.Low, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

            <TextBlock Grid.Row="10" Grid.Column="0" Text="High" />
            <TextBox Grid.Row="10" Grid.Column="2" Text="{Binding LimitEditor.High, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

            <TextBlock Grid.Row="12" Grid.Column="0" Text="Unit" />
            <TextBox Grid.Row="12" Grid.Column="2" Text="{Binding LimitEditor.Unit, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
        </Grid>
    </Grid>
</UserControl>
