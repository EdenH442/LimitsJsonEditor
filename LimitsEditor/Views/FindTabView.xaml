<UserControl x:Class="LimitsEditor.Views.FindTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <Grid Margin="8">
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <materialDesign:Card Padding="16" UniformCornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               FontWeight="SemiBold"
                               Text="Find" />
                    <TextBlock Grid.Row="2"
                               Opacity="0.7"
                               Text="Filters sequences as you type" />
                </Grid>

                <TextBox Grid.Row="2"
                         materialDesign:HintAssist.Hint="Find sequences"
                         Text="{Binding SequenceSearchText, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="1.7*" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Padding="12" UniformCornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontWeight="SemiBold" Text="Sequences" />
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding MatchingSequences}"
                             DisplayMemberPath="SeqName"
                             SelectedItem="{Binding SelectedSequence}" />
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2" Padding="12" UniformCornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontWeight="SemiBold" Text="Tests" />
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding TestsInSelectedSequence}"
                             DisplayMemberPath="StepName"
                             SelectedItem="{Binding SelectedTest}" />
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="4" Padding="12" UniformCornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontWeight="SemiBold" Text="Limits" />

                    <ListBox Grid.Row="2"
                             MaxHeight="140"
                             ItemsSource="{Binding LimitsInSelectedTest}"
                             SelectedItem="{Binding SelectedLimit}"
                             Visibility="{Binding IsMultipleTestSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,0,6"
                                           VerticalAlignment="Center"
                                           Text="{Binding MultipleStepNameCheck}"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="4"
                            Padding="10"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock FontWeight="SemiBold" Text="Limit Details" />

                                <Button Grid.Column="1"
                                        Padding="10,4"
                                        Command="{Binding EditLimitCommand}"
                                        Content="Edit" />
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="120" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Multiple Step"
                                           Visibility="{Binding IsMultipleTestSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           Text="{Binding SelectedLimit.MultipleStepNameCheck, TargetNullValue=-}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding IsMultipleTestSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Limit Type" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding SelectedLimit.LimitType, TargetNullValue=-}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Comparison" />
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding SelectedLimit.ComparisonType, TargetNullValue=-}" />

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Threshold Type" />
                                <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding SelectedLimit.ThresholdType, TargetNullValue=-}" />

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Expected" />
                                <TextBlock Grid.Row="8" Grid.Column="2" Text="{Binding SelectedLimit.ExpectedRes, TargetNullValue=-}" />

                                <TextBlock Grid.Row="10" Grid.Column="0" Text="Low" />
                                <TextBlock Grid.Row="10" Grid.Column="2" Text="{Binding SelectedLimit.Low, TargetNullValue=-}" />

                                <TextBlock Grid.Row="12" Grid.Column="0" Text="High" />
                                <TextBlock Grid.Row="12" Grid.Column="2" Text="{Binding SelectedLimit.High, TargetNullValue=-}" />

                                <TextBlock Grid.Row="14" Grid.Column="0" Text="Unit" />
                                <TextBlock Grid.Row="14" Grid.Column="2" Text="{Binding SelectedLimit.Unit, TargetNullValue=-}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <TextBlock Grid.Row="4" Opacity="0.75" Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>
