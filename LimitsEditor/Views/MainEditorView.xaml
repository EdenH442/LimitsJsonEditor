<UserControl x:Class="LimitsEditor.Views.MainEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <Grid Margin="8">
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <Style x:Key="SectionCardStyle" TargetType="materialDesign:Card">
                <Setter Property="Padding" Value="18" />
                <Setter Property="UniformCornerRadius" Value="12" />
                <Setter Property="Margin" Value="0" />
            </Style>

            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="17" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="SectionActionButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="12,7" />
                <Setter Property="Margin" Value="0,0,8,0" />
                <Setter Property="MinWidth" Value="118" />
            </Style>

            <Style x:Key="ListPanelBorderStyle" TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="8" />
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.15*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="1.4*" />
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Sequences" />
                    <materialDesign:PackIcon Grid.Column="1" Width="20" Height="20" Kind="FormatListBulletedSquare" />
                </Grid>

                <TextBlock Grid.Row="2"
                           Style="{StaticResource SubtleTextStyle}"
                           Text="Search and choose a sequence to inspect related tests." />

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 materialDesign:HintAssist.Hint="Search by sequence name"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Grid.Column="2"
                                Padding="14,7"
                                Command="{Binding FindSequenceCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,6,0" Kind="Magnify" />
                                <TextBlock Text="Find" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Grid.Row="2" Style="{StaticResource ListPanelBorderStyle}">
                        <ListBox ItemsSource="{Binding FilteredSequences}"
                                 BorderThickness="0"
                                 DisplayMemberPath="Name"
                                 SelectedItem="{Binding SelectedSequence}" />
                    </Border>
                </Grid>

                <WrapPanel Grid.Row="6" Orientation="Horizontal">
                    <Button Style="{StaticResource SectionActionButtonStyle}" Command="{Binding AddSequenceCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,6,0" Kind="PlusCircleOutline" />
                            <TextBlock Text="Add Sequence" />
                        </StackPanel>
                    </Button>
                    <Button Padding="12,7" MinWidth="118" Command="{Binding DeleteSequenceCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,6,0" Kind="DeleteOutline" />
                            <TextBlock Text="Delete Sequence" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="2" Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Tests" />
                    <materialDesign:PackIcon Grid.Column="1" Width="20" Height="20" Kind="PlaylistCheck" />
                </Grid>

                <TextBlock Grid.Row="2"
                           Style="{StaticResource SubtleTextStyle}"
                           Text="Tests are shown for the currently selected sequence." />

                <Border Grid.Row="4" Style="{StaticResource ListPanelBorderStyle}">
                    <ListBox ItemsSource="{Binding SelectedSequenceTests}"
                             BorderThickness="0"
                             DisplayMemberPath="Name"
                             SelectedItem="{Binding SelectedTest}" />
                </Border>

                <WrapPanel Grid.Row="6" Orientation="Horizontal">
                    <Button Style="{StaticResource SectionActionButtonStyle}" Command="{Binding AddTestCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,6,0" Kind="PlusCircleOutline" />
                            <TextBlock Text="Add Test" />
                        </StackPanel>
                    </Button>
                    <Button Padding="12,7" MinWidth="118" Command="{Binding DeleteTestCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,6,0" Kind="DeleteOutline" />
                            <TextBlock Text="Delete Test" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="4" Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Details Editor" />
                    <materialDesign:PackIcon Grid.Column="1" Width="20" Height="20" Kind="FileDocumentEditOutline" />
                </Grid>

                <TextBlock Grid.Row="2"
                           Style="{StaticResource SubtleTextStyle}"
                           Text="Review and edit selected limit values before saving the file." />

                <TextBlock Grid.Row="4"
                           FontWeight="SemiBold"
                           Text="Limit item (MULTIPLE tests)"
                           Visibility="{Binding IsMultipleTestSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <Border Grid.Row="6"
                        Padding="10"
                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ListBox Grid.Row="0"
                                 Height="92"
                                 BorderThickness="0"
                                 ItemsSource="{Binding LimitsInSelectedTest}"
                                 SelectedItem="{Binding SelectedLimit}"
                                 Visibility="{Binding IsMultipleTestSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,0,0,4"
                                               Text="{Binding MultipleStepNameCheck, TargetNullValue='(unnamed)'}"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="2" IsEnabled="{Binding HasEditableLimit}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="132" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="Multiple Step"
                                       Visibility="{Binding IsMultipleTestSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="2"
                                     Text="{Binding EditableLimit.MultipleStepNameCheck, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                     Visibility="{Binding IsMultipleTestSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Limit Type" />
                            <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding EditableLimit.LimitType, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Comparison" />
                            <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding EditableLimit.ComparisonType, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Threshold Type" />
                            <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding EditableLimit.ThresholdType, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Expected" />
                            <TextBox Grid.Row="8" Grid.Column="2" Text="{Binding EditableLimit.ExpectedRes, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                            <TextBlock Grid.Row="10" Grid.Column="0" Text="Low" />
                            <TextBox Grid.Row="10" Grid.Column="2" Text="{Binding EditableLimit.Low, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                            <TextBlock Grid.Row="12" Grid.Column="0" Text="High" />
                            <TextBox Grid.Row="12" Grid.Column="2" Text="{Binding EditableLimit.High, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                            <TextBlock Grid.Row="14" Grid.Column="0" Text="Unit" />
                            <TextBox Grid.Row="14" Grid.Column="2" Text="{Binding EditableLimit.Unit, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                        </Grid>
                    </Grid>
                </Border>

                <WrapPanel Grid.Row="8" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource SectionActionButtonStyle}" Command="{Binding EditLimitCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,6,0" Kind="PencilOutline" />
                            <TextBlock Text="Edit Selected" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SectionActionButtonStyle}" Command="{Binding CancelEditCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,6,0" Kind="CloseCircleOutline" />
                            <TextBlock Text="Cancel" />
                        </StackPanel>
                    </Button>
                    <Button Padding="12,7"
                            MinWidth="118"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding SaveChangesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,6,0" Kind="ContentSaveOutline" />
                            <TextBlock Text="Apply Edit" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
