<Window x:Class="LimitsEditor.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:LimitsEditor.Views"
        mc:Ignorable="d"
        Title="Limits JSON Editor"
        Height="860"
        Width="1360"
        MinHeight="700"
        MinWidth="1080"
        TextElement.FontSize="14"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <materialDesign:Card Padding="18" UniformCornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="30" FontWeight="SemiBold" Text="Limits JSON Editor" />
                    <TextBlock Style="{StaticResource SubtleTextStyle}" Text="One focused workspace for sequence search, test browsing, and detail editing." />
                </StackPanel>

                <Button Grid.Column="1"
                        VerticalAlignment="Top"
                        Padding="14,6"
                        Command="{Binding ToggleThemeCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ThemeLightDark" Width="18" Height="18" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding ThemeToggleButtonText}" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="2" Padding="16" UniformCornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Margin="0,0,10,0"
                         materialDesign:HintAssist.Hint="JSON file path"
                         Text="{Binding SelectedFilePath, UpdateSourceTrigger=PropertyChanged}" />

                <Button Grid.Column="1"
                        Margin="0,0,10,0"
                        Padding="14,6"
                        Command="{Binding BrowseFileCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderSearchOutline" Width="18" Height="18" Margin="0,0,6,0" />
                        <TextBlock Text="Browse" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Margin="0,0,10,0"
                        Padding="14,6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding OpenFileCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDownloadOutline" Width="18" Height="18" Margin="0,0,6,0" />
                        <TextBlock Text="Open" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="3"
                        Padding="14,6"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding SaveFileCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="18" Height="18" Margin="0,0,6,0" />
                        <TextBlock Text="Save File" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>

        <views:MainEditorView Grid.Row="4" DataContext="{Binding MainEditor}" />

        <materialDesign:Card Grid.Row="6" Padding="10,8" UniformCornerRadius="8">
            <TextBlock Opacity="0.8"
                       TextWrapping="Wrap"
                       Text="{Binding StatusMessage}" />
        </materialDesign:Card>
    </Grid>
</Window>
