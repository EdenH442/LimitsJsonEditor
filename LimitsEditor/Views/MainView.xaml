<Window x:Class="LimitsEditor.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Limits JSON Editor"
        Height="560"
        Width="900">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Limits JSON Editor"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <Grid Grid.Row="1"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     MinWidth="300"
                     Margin="0,0,8,0"
                     Text="{Binding SelectedFilePath, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="1"
                    Content="Browse"
                    Command="{Binding BrowseFileCommand}"
                    Margin="0,0,8,0"
                    Padding="12,4" />
            <Button Grid.Column="2"
                    Content="Load"
                    Command="{Binding LoadFileCommand}"
                    Padding="12,4" />
        </Grid>

        <Grid Grid.Row="2"
              Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Text="Sequence Name:" />
            <TextBox Grid.Column="1"
                     Margin="0,0,16,0"
                     Text="{Binding SequenceName, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Column="2"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Text="Test Name:" />
            <TextBox Grid.Column="3"
                     Text="{Binding TestName, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <Grid Grid.Row="3"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Text="Test Type:" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding AvailableTestTypes}"
                      SelectedItem="{Binding TestType}" />
        </Grid>

        <Border Grid.Row="4"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="TestValues"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding TestValues}"
                         Margin="0,0,0,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#FFE1E1E1"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="8"
                                    Margin="0,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="TestValue item"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="ResultType / ExpectedResult / Comparison / Min / Max"
                                               Foreground="Gray"
                                               FontSize="11" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="2"
                        HorizontalAlignment="Left"
                        Content="Add TestValue"
                        Command="{Binding AddTestValueCommand}"
                        Padding="12,4" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="5">
            <Button DockPanel.Dock="Right"
                    Content="Apply"
                    Command="{Binding ApplyChangesCommand}"
                    Padding="14,5" />
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding StatusMessage}" />
        </DockPanel>
    </Grid>
</Window>
